# MongoDB (obrigatório)
MONGO_URI=mongodb://localhost:27017
DB_NAME=ambev

# CORS: URL do frontend que pode chamar a API (sem barra no final).
# Várias origens: separar por vírgula, ex.: https://app.com,https://www.app.com
FRONTEND_URL=http://localhost:5173

# Deploy: a maioria das plataformas define PORT automaticamente.
# Opcional em local; em produção use FLASK_ENV=production para desativar debug.
# PORT=5000
# FLASK_ENV=production
